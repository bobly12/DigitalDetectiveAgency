<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Digital Detective Agency</title>
    <!-- Using standard Bootstrap via CDN for quick, clean game layout prototyping -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-black border-bottom border-secondary box-shadow mb-4">
            <div class="container-fluid mx-4">
                <a class="navbar-brand fw-bold text-danger" asp-area="" asp-controller="Dashboard" asp-action="Index">🕵️ Digital Detective Agency</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Case" asp-action="Index">Case Board</a>
                        </li>
                    </ul>
                    
                    <!-- Right side of navbar for user status -->
                    <div class="d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-secondary me-3">Active Badge: @User.Identity.Name</span>
                            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-outline-sm btn-outline-danger btn-sm">Log Out</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-sm btn-outline-success btn-sm" asp-controller="Account" asp-action="Login">Log In</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary footer text-muted bg-black fixed-bottom py-2 mt-5">
        <div class="container text-center text-secondary" style="font-size: 0.85rem;">
            &copy; @DateTime.UtcNow.Year - Digital Detective Agency Backend Engine Framework
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>